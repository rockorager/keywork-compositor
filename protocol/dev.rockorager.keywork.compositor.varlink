# Control the Keywork compositor's built-in window-management policy.
interface dev.rockorager.keywork.compositor

# A direction relative to the currently focused window.
type Direction (next, previous, left, down, up, right)

# A window selected for an operation.
type WindowTarget (focused)

# A built-in workspace layout.
type Layout (tiled)

# Logging verbosity selected for the compositor.
type LogLevel (error, warning, info, debug)

# An RGBA color with channels in the inclusive range 0 through 255.
type Color (
    red: int,
    green: int,
    blue: int,
    alpha: int
)

# A window border. A width of zero disables the border.
type Border (
    width: int,
    color: Color
)

# A rectangle in global logical compositor coordinates.
type Rectangle (
    x: int,
    y: int,
    width: int,
    height: int
)

# The protocol through which a window is managed.
type WindowProtocol (xdg_shell, xwayland)

# A snapshot of a managed window. The opaque ID is unique for the compositor's lifetime.
# The rectangle is absent when the window has no published geometry.
type Window (
    id: string,
    protocol: WindowProtocol,
    title: ?string,
    app_id: ?string,
    pid: ?int,
    rect: ?Rectangle,
    output: string,
    workspace: int,
    focused: bool,
    visible: bool,
    floating: bool,
    fullscreen: bool,
    maximized: bool,
    minimized: bool
)

# Rolling latency distribution in microseconds.
type LatencyStatistics (
    samples: int,
    p50_microseconds: int,
    p95_microseconds: int,
    p99_microseconds: int,
    maximum_microseconds: int
)

# Reasons composited frames could not use direct scanout.
type DirectScanoutRejections (
    no_fullscreen_surface: int,
    non_opaque_surface: int,
    surface_transform: int,
    non_dmabuf: int,
    y_inverted: int,
    missing_buffer_identity: int,
    color_conversion: int,
    unsupported_backend: int,
    output_unavailable: int,
    output_busy: int,
    device_inactive: int,
    unsupported_format_or_modifier: int,
    unsupported_layout: int,
    framebuffer_import_failed: int,
    page_flip_failed: int
)

# Reasons composited images could not be promoted to an overlay plane.
type OverlayScanoutRejections (
    no_topmost_surface: int,
    non_opaque_surface: int,
    clipped_surface: int,
    transformed_surface: int,
    scaled_surface: int,
    outside_output: int,
    non_dmabuf: int,
    non_rgb_surface: int,
    y_inverted: int,
    missing_buffer_identity: int,
    color_conversion: int,
    unsupported_backend: int,
    output_unavailable: int,
    output_busy: int,
    device_inactive: int,
    no_overlay_plane: int,
    unsupported_format_or_modifier: int,
    unsupported_layout: int,
    synchronization_failed: int,
    framebuffer_import_failed: int,
    atomic_test_failed: int,
    page_flip_failed: int
)

# The path used for the most recently committed frame.
type FramePath (none, composited, direct_scanout, overlay_scanout)

# A renderer working or output scanout buffer format.
type BufferFormat (none, argb8888, xrgb8888, abgr8888, xbgr8888, xrgb2101010, rgba16f_linear)

# The output-space transform applied during presentation.
type OutputTransform (normal)

# Diagnostic state for the most recently committed frame.
type FrameDiagnostics (
    path: FramePath,
    working_format: BufferFormat,
    scanout_format: BufferFormat,
    output_transform: OutputTransform,
    damage_rectangles: int,
    damaged_pixels: int
)

# Per-output frame processing and presentation statistics.
type OutputStatistics (
    name: string,
    width: int,
    height: int,
    refresh_millihertz: int,
    last_frame: FrameDiagnostics,
    frames_requested: int,
    frames_started: int,
    frames_presented: int,
    frames_discarded: int,
    acquire_retries: int,
    composited_frames: int,
    direct_scanout_candidates: int,
    direct_scanout_frames: int,
    direct_scanout_rejections: DirectScanoutRejections,
    overlay_scanout_candidates: int,
    overlay_scanout_frames: int,
    overlay_scanout_rejections: OverlayScanoutRejections,
    cpu_uploads: int,
    dmabuf_imports: int,
    frames_over_budget: int,
    gpu_execution: LatencyStatistics,
    gpu_composition: LatencyStatistics,
    gpu_preparation: LatencyStatistics,
    gpu_solid_composition: LatencyStatistics,
    gpu_image_composition: LatencyStatistics,
    gpu_shadow: LatencyStatistics,
    gpu_blur_downsample: LatencyStatistics,
    gpu_blur_upsample: LatencyStatistics,
    gpu_blur_composite: LatencyStatistics,
    gpu_composition_overhead: LatencyStatistics,
    gpu_output_encode: LatencyStatistics,
    gpu_frame_finish: LatencyStatistics,
    request_to_presentation: LatencyStatistics,
    request_to_render: LatencyStatistics,
    render_to_commit: LatencyStatistics,
    commit_to_presentation: LatencyStatistics,
    render_fence_samples: int,
    render_fences_signaled_before_commit: int,
    render_to_gpu_completion: LatencyStatistics,
    gpu_completion_to_presentation: LatencyStatistics
)

# Instantaneous compositor-owned resource state. Mapped buffer capacity is the
# usable capacity of retained renderer staging and instance buffers; it excludes
# Vulkan image allocations, client-owned buffers, and process memory.
type ResourceStatistics (
    renderer_targets: int,
    pixel_renderer_targets: int,
    offscreen_renderer_targets: int,
    dmabuf_renderer_targets: int,
    cached_textures: int,
    imported_textures: int,
    pending_textures: int,
    pending_gpu_submissions: int,
    calibration_textures: int,
    video_graphics_pipelines: int,
    blur_scratch_images: int,
    backdrop_cache_images: int,
    mapped_buffer_capacity_bytes: int,
    linux_dmabuf_buffers: int,
    screencopy_frames: int,
    image_copy_capture_sessions: int,
    image_copy_capture_frames: int,
    capture_buffers: int
)

# Change focus within the active workspace.
method Focus (direction: Direction) -> ()

# Reorder the focused window within the active workspace.
method MoveFocused (direction: Direction) -> ()

# Ask a window to close.
method Close (target: WindowTarget) -> ()

# Toggle whether a window fills its output.
method ToggleFullscreen (target: WindowTarget) -> ()

# Toggle whether a window participates in the tiling layout.
method ToggleFloating (target: WindowTarget) -> ()

# Change the active workspace's layout.
method SetLayout (layout: Layout) -> ()

# Activate a numbered workspace on the focused output.
method SwitchWorkspace (workspace: int) -> ()

# Move the focused window to a numbered workspace on the focused output.
method MoveFocusedToWorkspace (workspace: int) -> ()

# Return a snapshot of mapped windows and their published logical geometry.
method GetWindows () -> (windows: []Window)

# Return per-output performance counters and instantaneous resource state, then
# optionally reset only the performance counters.
method GetPerformanceStatistics (reset: bool) -> (outputs: []OutputStatistics, resources: ?ResourceStatistics)

# Change the border rendered around unfocused windows and window-like layer surfaces.
method SetUnfocusedBorder (border: Border) -> ()

# Change the maximum log level without restarting the compositor.
method SetLogLevel (level: LogLevel) -> ()

# Parse and atomically apply the selected configuration.
method ReloadConfiguration () -> ()

# Shut down the Keywork graphical session.
method Quit () -> ()

# The requested workspace number is outside Keywork's supported range.
error InvalidWorkspace (workspace: int)

# The selected configuration could not be read or validated.
error ConfigurationReloadFailed (message: string)
