# Control the Keywork compositor's built-in window-management policy.
interface dev.rockorager.keywork.compositor

# A direction relative to the currently focused window.
type Direction (next, previous, left, down, up, right)

# A window selected for an operation.
type WindowTarget (focused)

# A built-in tiling layout.
type Layout (master_stack, dwindle, scrolling)

# Rolling latency distribution in microseconds.
type LatencyStatistics (
    samples: int,
    p50_microseconds: int,
    p95_microseconds: int,
    p99_microseconds: int,
    maximum_microseconds: int
)

# Per-output frame processing and presentation statistics.
type OutputStatistics (
    name: string,
    width: int,
    height: int,
    refresh_millihertz: int,
    frames_requested: int,
    frames_started: int,
    frames_presented: int,
    frames_discarded: int,
    acquire_retries: int,
    composited_frames: int,
    direct_scanout_candidates: int,
    direct_scanout_frames: int,
    frames_over_budget: int,
    request_to_presentation: LatencyStatistics,
    request_to_render: LatencyStatistics,
    render_to_commit: LatencyStatistics,
    commit_to_presentation: LatencyStatistics
)

# Change focus within the active workspace.
method Focus (direction: Direction) -> ()

# Reorder the focused window within the active workspace.
method MoveFocused (direction: Direction) -> ()

# Ask a window to close.
method Close (target: WindowTarget) -> ()

# Toggle whether a window fills its output.
method ToggleFullscreen (target: WindowTarget) -> ()

# Toggle whether a window participates in the tiling layout.
method ToggleFloating (target: WindowTarget) -> ()

# Change the active workspace's layout.
method SetLayout (layout: Layout) -> ()

# Activate a numbered workspace on the focused output.
method SwitchWorkspace (workspace: int) -> ()

# Move the focused window to a numbered workspace on the focused output.
method MoveFocusedToWorkspace (workspace: int) -> ()

# Return a snapshot of per-output frame statistics, then optionally reset them.
method GetPerformanceStatistics (reset: bool) -> (outputs: []OutputStatistics)

# Parse and atomically apply the selected configuration.
method ReloadConfiguration () -> ()

# Shut down the Keywork graphical session.
method Quit () -> ()

# The requested workspace number is outside Keywork's supported range.
error InvalidWorkspace (workspace: int)

# The selected configuration could not be read or validated.
error ConfigurationReloadFailed (message: string)
